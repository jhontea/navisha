# Location autocomplete provider (server-side key; never expose to frontend)
GEOAPIFY_API_KEY=
# Optional override for tests/self-hosted compatible services
GEOAPIFY_BASE_URL=https://api.geoapify.com/v1/geocode/autocomplete
# OpenRouter — AI features (trip summary, auto-generate). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/owl-alpha
# LLM Provider — set to "deepseek" to use DeepSeek instead of "openrouter".
# When empty, falls back to the OpenRouter config above.
LLM_PROVIDER=
# DeepSeek — alternative AI provider. Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
