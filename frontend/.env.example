NEXT_PUBLIC_API_URL=http://localhost:8090/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Location autocomplete: geoapify (backend proxy) or google
NEXT_PUBLIC_LOCATION_PROVIDER=geoapify
# Map renderer: maplibre, google, or disabled
NEXT_PUBLIC_MAP_PROVIDER=maplibre
# Optional browser-facing MapLibre tiles. Defaults to the same-origin proxy.
# NEXT_PUBLIC_MAP_TILE_URL=/api/map-tiles/{z}/{x}/{y}
# NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors © CARTO
# Optional server-side tile source used by the same-origin proxy.
# MAP_TILE_UPSTREAM_URL=https://basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png
# Google Places photos remain opt-in and are disabled by default
NEXT_PUBLIC_LOCATION_PHOTOS_ENABLED=false
